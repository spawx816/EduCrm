# iRedMail & SMTP Configuration
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=notifications@yourdomain.com
SMTP_PASS=your_password
SMTP_FROM=notifications@yourdomain.com

# iRedMail Account Management (SSH)
IREDMAIL_SSH_HOST=mail.yourdomain.com
IREDMAIL_SSH_PORT=22
IREDMAIL_SSH_USER=root
IREDMAIL_SSH_PASS=your_root_password
IREDMAIL_DOMAIN=yourdomain.com
IREDMAIL_SCRIPT_PATH=/opt/iredmail/tools/create_mail_user_SQL.sh
